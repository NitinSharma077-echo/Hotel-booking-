# ─── RapidAPI Booking.com ───────────────────────────────────────────────────
# Get your free key at: https://rapidapi.com/tipsters/api/booking-com
# Sign up → Subscribe to Basic (free 500 req/month) → Copy X-RapidAPI-Key
RAPIDAPI_KEY=

# ─── Ollama (local LLM) ─────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
REDIS_HOST=localhost
REDIS_PORT=6379
MONGO_URI=mongodb://localhost:27017
MONGO_DB=hotel_agent
BOOKING_USERNAME=your_email@example.com
BOOKING_PASSWORD=your_password
HEADLESS=false
